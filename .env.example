# eTrade API Credentials — Sandbox (Paper Trading) Only
#
# HOW TO USE:
#   1. Copy this file and rename the copy to exactly:  .env
#   2. Replace the placeholder values below with your real Sandbox keys
#      from developer.etrade.com
#   3. Save the file — the bot will load these automatically on startup
#
# ⚠️  IMPORTANT SECURITY RULES:
#   • Never share your .env file with anyone
#   • Never upload it to GitHub or cloud storage
#   • The .env file stays on your computer only
#   • These are SANDBOX keys (paper trading) — not your real account password

SANDBOX_CONSUMER_KEY=your_sandbox_consumer_key_here
SANDBOX_CONSUMER_SECRET=your_sandbox_consumer_secret_here
